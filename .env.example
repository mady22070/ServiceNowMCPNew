# ServiceNow Instance Configuration
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com

# Authentication - Basic Auth
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=your-password

# Authentication - OAuth2 (optional, takes precedence over Basic Auth)
# SERVICENOW_OAUTH_CLIENT_ID=your-client-id
# SERVICENOW_OAUTH_CLIENT_SECRET=your-client-secret

# Pack Configuration - comma-separated list of enabled packs
# Available packs: admin, development, itsm, itom, troubleshooting
SERVICENOW_ENABLED_PACKS=admin,development,itsm,itom,troubleshooting

# API Settings
SERVICENOW_API_TIMEOUT=30000
SERVICENOW_PAGE_SIZE=100
